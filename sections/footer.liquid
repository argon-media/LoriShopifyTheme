{%- comment -%}
  Footer Section - Lori J. Smith Theme
  Structure:
  1. Bio & Navigation Section (3 columns)
  2. Tan Newsletter Band
  3. Instagram Section (tan background with text left, grid right)
  4. Copyright Bar
{%- endcomment -%}

<footer class="site-footer">
  <!-- 1. BIO & NAVIGATION SECTION -->
  <div class="footer-main">
    <div class="footer-grid">
      
      <!-- Left: GET AROUND - Navigation -->
      <div class="footer-nav">
        <h4 class="footer-nav-title">{{ section.settings.nav_title | default: 'GET AROUND' }}</h4>
        <div class="footer-nav-links">
          {%- for block in section.blocks -%}
            {%- if block.type == 'nav_link' -%}
              <a href="{{ block.settings.link_url }}" class="footer-nav-link" {{ block.shopify_attributes }}>
                {{ block.settings.link_text }}
              </a>
            {%- endif -%}
          {%- endfor -%}
          
          {%- assign nav_link_count = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'nav_link' -%}
              {%- assign nav_link_count = nav_link_count | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
          
          {%- if nav_link_count == 0 -%}
            <a href="https://lorijsmith.com/" class="footer-nav-link">Home</a>
            <a href="https://lorijsmith.com/learn-with-lori/" class="footer-nav-link">Learn With Lori</a>
            <a href="https://lorijsmith.com/about/" class="footer-nav-link">About</a>
            <a href="https://lorijsmith.com/contact/" class="footer-nav-link">Get In Touch</a>
            <a href="https://lorijsmith.com/the-ljs-blog/" class="footer-nav-link">The Blog</a>
            <a href="https://lorijsmith.com/my-account/" class="footer-nav-link">My Account</a>
            <a href="https://lorijsmith.com/the-shop/" class="footer-nav-link">The Shop</a>
            <a href="https://lorijsmith.com/faqs/" class="footer-nav-link">FAQs</a>
          {%- endif -%}
        </div>
        <a href="{{ section.settings.student_login_url | default: '/account/login' }}" class="footer-student-btn">
          {{ section.settings.student_login_text | default: 'STUDENT LOGIN' }}
        </a>
      </div>

      <!-- Middle: BIO SECTION -->
      <div class="footer-bio">
        <span class="footer-bio-greeting font-script">{{ section.settings.bio_greeting | default: 'hey there!' }}</span>
        <h4 class="footer-bio-name">{{ section.settings.bio_name | default: "I'm Lori J Smith" }}</h4>
        <p class="footer-bio-text">
          {{ section.settings.bio_text | default: "Homebody, & yet somehow also aspiring frequent flyer, midwest based online coach & educator, wife, mom, lolo & 'mama' to two golden-doodles, obsessive researcher, lifelong student. I'm glad you're here." }}
        </p>
        
        <!-- Social Icons -->
        <div class="footer-social">
          {%- if section.settings.social_tiktok != blank -%}
            <a href="{{ section.settings.social_tiktok }}" class="footer-social-link" aria-label="TikTok">
              <svg class="footer-social-icon" viewBox="0 0 24 24" fill="currentColor">
                <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"/>
              </svg>
            </a>
          {%- else -%}
            <a href="#" class="footer-social-link" aria-label="TikTok">
              <svg class="footer-social-icon" viewBox="0 0 24 24" fill="currentColor">
                <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"/>
              </svg>
            </a>
          {%- endif -%}
          
          {%- if section.settings.social_facebook != blank -%}
            <a href="{{ section.settings.social_facebook }}" class="footer-social-link" aria-label="Facebook">
              <svg class="footer-social-icon" viewBox="0 0 24 24">
                <path d="M22.675 0h-21.35c-.732 0-1.325.593-1.325 1.325v21.351c0 .731.593 1.324 1.325 1.324h11.495v-9.294h-3.128v-3.622h3.128v-2.671c0-3.1 1.893-4.788 4.659-4.788 1.325 0 2.463.099 2.795.143v3.24l-1.918.001c-1.504 0-1.795.715-1.795 1.763v2.312h3.587l-.467 3.622h-3.12v9.293h6.116c.73 0 1.323-.593 1.323-1.325v-21.35c0-.732-.593-1.325-1.325-1.325z"/>
