      <span class="footer-copyright-divider">|</span>
      <a href="{{ section.settings.privacy_url | default: 'https://lorijsmith.com/privacy-policy/' }}" class="footer-copyright-link">{{ section.settings.privacy_text | default: 'Privacy' }}</a>
    </div>
  </div>
</footer>

