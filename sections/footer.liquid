      </div>

      <!-- Right: Portrait Square -->
      <div class="footer-portrait">
        <div class="footer-portrait-image">
          {%- if section.settings.portrait_image -%}
            <img 
              src="{{ section.settings.portrait_image | image_url: width: 680 }}" 
              alt="{{ section.settings.bio_name | default: 'Lori J Smith' }}"
            >
          {%- else -%}
            <img 
              src="https://lorijsmith.com/wp-content/uploads/2023/03/IMG_1725_Facetune_01-11-2021-09-16-13.jpg" 
              alt="Lori J Smith Portrait"
            >
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>

  <!-- 2. TAN NEWSLETTER BAND -->
  <div class="footer-newsletter">
    <div class="footer-newsletter-inner">
      <p class="footer-newsletter-label">subscribe to the</p>
      <h2 class="footer-newsletter-title font-script">{{ section.settings.newsletter_title | default: 'Weekly Bookmark' }}</h2>
      <p class="footer-newsletter-text">
        {{ section.settings.newsletter_description | default: 'A simple weekly touchpoint to help you build a beautiful life one rhythm, one thought, one week at a time.' }}
      </p>
      
      <form
        action="https://lorijsmith.us5.list-manage.com/subscribe/post?u=ce5b25d7e73f18ff0a5c2ad81&amp;id=55ace7222c&amp;f_id=00a2a3e6f0"
        method="post"
        target="_blank"
        class="footer-newsletter-form"
        novalidate
      >
        <div class="footer-newsletter-name">
          <input 
            type="text" 
            name="FNAME"
            placeholder="{{ section.settings.name_placeholder | default: 'Name' }}"
            class="footer-newsletter-input"
          >
        </div>
        <div class="footer-newsletter-email">
          <input 
            type="email" 
            name="EMAIL"
            placeholder="{{ section.settings.email_placeholder | default: 'Email' }}"
            class="footer-newsletter-input"
            required
          >
        </div>
        <div aria-hidden="true" style="position:absolute;left:-5000px;">
          <input type="text" name="b_ce5b25d7e73f18ff0a5c2ad81_55ace7222c" tabindex="-1" value="">
        </div>
        <div class="footer-newsletter-submit">
          <button type="submit" class="footer-newsletter-btn">
            {{ section.settings.newsletter_button | default: 'Yes, I Want the Weekly Bookmark!' }}
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- 3. INSTAGRAM SECTION (Below Newsletter) -->
  <div class="footer-instagram">
    <div class="footer-instagram-content">
      <!-- Left: Text with Segatha script font -->
      <div class="footer-instagram-text">
        <h2 class="footer-instagram-heading font-script">Come say hi<br>on the 'gram!</h2>
        <a href="{{ section.settings.instagram_url | default: 'https://www.instagram.com/lorijsmithco/' }}" target="_blank" class="footer-instagram-handle">
          {{ section.settings.instagram_handle | default: '@lorijsmithco' }}
        </a>
      </div>
      
      <!-- Right: Instagram Grid -->
      <div class="footer-instagram-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'instagram_post' -%}
            <a href="{{ block.settings.post_url | default: '#' }}" target="_blank" rel="noopener nofollow" class="footer-instagram-item" {{ block.shopify_attributes }}>
              {%- if block.settings.post_image -%}
                <img src="{{ block.settings.post_image | image_url: width: 400 }}" alt="Instagram post" loading="lazy">
              {%- else -%}
                <img src="{{ block.settings.post_image_url | default: 'https://placehold.co/200x200/EBC199/ffffff?text=IG' }}" alt="Instagram post" loading="lazy">
              {%- endif -%}
              {%- if block.settings.is_video -%}
                <svg class="footer-instagram-play" viewBox="0 0 448 512" aria-hidden="true">
                  <path fill="currentColor" d="M424.4 214.7L72.4 6.6C43.8-10.3 0 6.1 0 47.9V464c0 37.5 40.7 60.1 72.4 41.3l352-208c31.4-18.5 31.5-64.1 0-82.6z"/>
                </svg>
              {%- endif -%}
            </a>
          {%- endif -%}
        {%- endfor -%}
        
        {%- comment %} Show placeholder posts if none configured {% endcomment -%}
        {%- assign instagram_post_count = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'instagram_post' -%}
            {%- assign instagram_post_count = instagram_post_count | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
        
        {%- if instagram_post_count == 0 -%}
          <a href="https://www.instagram.com/lorijsmithco/" target="_blank" rel="noopener nofollow" class="footer-instagram-item">
            <img src="https://lorijsmith.com/wp-content/uploads/sb-instagram-feed-images/279251632_382094840469024_1886711949968432510_nfull.jpg" alt="Instagram post" loading="lazy">
            <svg class="footer-instagram-play" viewBox="0 0 448 512" aria-hidden="true">
              <path fill="currentColor" d="M424.4 214.7L72.4 6.6C43.8-10.3 0 6.1 0 47.9V464c0 37.5 40.7 60.1 72.4 41.3l352-208c31.4-18.5 31.5-64.1 0-82.6z"/>
            </svg>
          </a>
          <a href="https://www.instagram.com/lorijsmithco/" target="_blank" rel="noopener nofollow" class="footer-instagram-item">
            <img src="https://lorijsmith.com/wp-content/uploads/sb-instagram-feed-images/275531287_534239611344707_4821377671136136193_nfull.jpg" alt="Instagram post" loading="lazy">
            <svg class="footer-instagram-play" viewBox="0 0 448 512" aria-hidden="true">
              <path fill="currentColor" d="M424.4 214.7L72.4 6.6C43.8-10.3 0 6.1 0 47.9V464c0 37.5 40.7 60.1 72.4 41.3l352-208c31.4-18.5 31.5-64.1 0-82.6z"/>
            </svg>
          </a>
          <a href="https://www.instagram.com/lorijsmithco/" target="_blank" rel="noopener nofollow" class="footer-instagram-item">
            <img src="https://lorijsmith.com/wp-content/uploads/sb-instagram-feed-images/275406424_450358230173759_2584886778098922557_nfull.jpg" alt="Instagram post" loading="lazy">
          </a>
          <a href="https://www.instagram.com/lorijsmithco/" target="_blank" rel="noopener nofollow" class="footer-instagram-item">
            <img src="https://lorijsmith.com/wp-content/uploads/sb-instagram-feed-images/275353676_120619177211724_8231397932934450014_nfull.jpg" alt="Instagram post" loading="lazy">
            <svg class="footer-instagram-play" viewBox="0 0 448 512" aria-hidden="true">
              <path fill="currentColor" d="M424.4 214.7L72.4 6.6C43.8-10.3 0 6.1 0 47.9V464c0 37.5 40.7 60.1 72.4 41.3l352-208c31.4-18.5 31.5-64.1 0-82.6z"/>
            </svg>
          </a>
          <a href="https://www.instagram.com/lorijsmithco/" target="_blank" rel="noopener nofollow" class="footer-instagram-item">
            <img src="https://lorijsmith.com/wp-content/uploads/sb-instagram-feed-images/275133625_398563505072951_8368333006010608814_nfull.jpg" alt="Instagram post" loading="lazy">
            <svg class="footer-instagram-play" viewBox="0 0 448 512" aria-hidden="true">
              <path fill="currentColor" d="M424.4 214.7L72.4 6.6C43.8-10.3 0 6.1 0 47.9V464c0 37.5 40.7 60.1 72.4 41.3l352-208c31.4-18.5 31.5-64.1 0-82.6z"/>
            </svg>
          </a>
          <a href="https://www.instagram.com/lorijsmithco/" target="_blank" rel="noopener nofollow" class="footer-instagram-item">
            <img src="https://lorijsmith.com/wp-content/uploads/sb-instagram-feed-images/275181426_720153625649271_3790138145786074895_nfull.jpg" alt="Instagram post" loading="lazy">
            <svg class="footer-instagram-play" viewBox="0 0 448 512" aria-hidden="true">
              <path fill="currentColor" d="M424.4 214.7L72.4 6.6C43.8-10.3 0 6.1 0 47.9V464c0 37.5 40.7 60.1 72.4 41.3l352-208c31.4-18.5 31.5-64.1 0-82.6z"/>
            </svg>
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>

  <!-- 4. COPYRIGHT BAR -->
  <div class="footer-copyright">
    <div class="footer-copyright-inner">
      <span class="footer-copyright-text">{{ section.settings.copyright_text | default: 'Copyright Lori J. Smith LLC' }}</span>
      <span class="footer-copyright-divider">|</span>
