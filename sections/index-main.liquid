{%- comment -%}
  Index Main Section - Lori J. Smith Theme
  Homepage with all sections
{%- endcomment -%}

{%- assign featured_product = all_products[section.settings.featured_product] -%}

<!-- HERO BANNER -->
<section class="hero-banner">
  <div class="hero-sidebar"></div>
  
  <div class="hero-content">
    <div class="hero-content-inner">
      <p class="hero-label">{{ section.settings.hero_label }}</p>
      <h1 class="hero-title">
        <span class="hero-title-line">{{ section.settings.hero_title_line1 }} <strong>{{ section.settings.hero_title_accent }}</strong></span>
        <span class="hero-title-subtitle italic">{{ section.settings.hero_title_line2 }}</span>
      </h1>
      <p class="hero-description">{{ section.settings.hero_description }}</p>
      <a href="#product-section" class="hero-cta">
        <span>{{ section.settings.hero_button_text }}</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="43" height="18" viewBox="0 0 43 18" fill="none"><path d="M0 9H42" stroke="currentColor"></path><path d="M33 18C33 10.5 42 9 42 9C42 9 33 7.5 33 0" stroke="currentColor" stroke-linejoin="round"></path></svg>
      </a>
    </div>
  </div>

  <div class="hero-image-container">
    <!-- Mobile/Tablet Image -->
    <picture>
      <source media="(max-width: 1023px)" srcset="{{ 'hero-mobile.png' | asset_url }}">
      <source media="(min-width: 1024px)" srcset="{% if section.settings.hero_image %}{{ section.settings.hero_image | image_url: width: 1200 }}{% else %}https://lorijsmith.com/wp-content/uploads/2024/06/journalstack1-scaled.jpg{% endif %}">
      <img src="{{ 'hero-mobile.png' | asset_url }}" alt="Hero" class="hero-image">
    </picture>
    <div class="hero-image-overlay"></div>
    <div class="hero-floating-card">
      <p class="hero-floating-card-title">{{ section.settings.floating_card_title }}</p>
      <p class="hero-floating-card-text">{{ section.settings.floating_card_subtitle }}</p>
    </div>
  </div>
</section>

<!-- PRODUCT SECTION -->
<section class="product-section" id="product-section">
  <div class="product-container">
    <div class="product-grid">
      
      <!-- Product Images Gallery -->
      <div class="product-gallery">
        <div class="product-gallery__main">
          {% if featured_product.featured_image %}
            <img src="{{ featured_product.featured_image | image_url: width: 800 }}" alt="{{ featured_product.title }}" class="product-gallery__main-image" id="mainProductImage">
          {% else %}
            <img src="https://lorijsmith.com/wp-content/uploads/2023/04/Outside-Cover.jpg" alt="Product" class="product-gallery__main-image" id="mainProductImage">
          {% endif %}
        </div>
        <div class="product-gallery__thumbs">
          {% if featured_product.images.size > 0 %}
            {% for image in featured_product.images %}
              <button class="product-gallery__thumb{% if forloop.first %} active{% endif %}" data-image-src="{{ image | image_url: width: 800 }}">
                <img src="{{ image | image_url: width: 200 }}" alt="{{ image.alt | default: featured_product.title }}">
              </button>
            {% endfor %}
          {% else %}
            <button class="product-gallery__thumb active" data-image-src="https://lorijsmith.com/wp-content/uploads/2023/04/Outside-Cover.jpg">
              <img src="https://lorijsmith.com/wp-content/uploads/2023/04/Outside-Cover.jpg" alt="Thumb 1">
            </button>
            <button class="product-gallery__thumb" data-image-src="https://lorijsmith.com/wp-content/uploads/2023/04/Inside-Cover.jpg">
              <img src="https://lorijsmith.com/wp-content/uploads/2023/04/Inside-Cover.jpg" alt="Thumb 2">
            </button>
            <button class="product-gallery__thumb" data-image-src="https://lorijsmith.com/wp-content/uploads/2023/04/Interior-Page-My-desired-week.jpg">
              <img src="https://lorijsmith.com/wp-content/uploads/2023/04/Interior-Page-My-desired-week.jpg" alt="Thumb 3">
            </button>
          {% endif %}
        </div>
      </div>

      <!-- Purchase Details -->
      <div class="product-info">
        <div class="product-info-header">
          <div class="product-collection-label">{{ section.settings.collection_label }}</div>
          
          <h2 class="product-title">
            {{ section.settings.product_title_line1 }}<br>
            <span class="italic">{{ section.settings.product_title_line2 }}</span>
          </h2>
          
          <p class="product-intro-text">{{ section.settings.product_intro }}</p>
        </div>
        
        <div class="product-description">
          <p>{{ section.settings.product_description }}</p>
          <p class="product-shipping-note">While supplies last, you can get your journal free — just cover the $10 flat-rate for shipping. <strong>Currently, we only ship within the United States.</strong></p>
        </div>

        <!-- Purchase Form -->
        {% comment %} Find Standard and Free Trial variants {% endcomment %}
        {% assign standard_variant = nil %}
        {% assign free_trial_variant = nil %}
        {% assign subscription_variant = nil %}
        {% assign standard_price = 0 %}
        {% assign highest_price = 0 %}
        
        {% if featured_product %}
          {% comment %} First pass: look for specific variant names {% endcomment %}
          {% for variant in featured_product.variants %}
            {% assign variant_title_lower = variant.title | downcase %}
            {% if variant_title_lower contains 'standard' or variant.title == 'Default Title' %}
              {% assign standard_variant = variant %}
              {% assign standard_price = variant.price %}
            {% elsif variant_title_lower contains 'subscription' %}
              {% assign subscription_variant = variant %}
            {% elsif variant_title_lower contains 'free' or variant_title_lower contains 'trial' %}
              {% assign free_trial_variant = variant %}
            {% endif %}
            
            {% comment %} Track highest price variant (excluding free trial and subscription) {% endcomment %}
            {% unless variant_title_lower contains 'free' or variant_title_lower contains 'trial' or variant_title_lower contains 'subscription' %}
              {% if variant.price > highest_price %}
                {% assign highest_price = variant.price %}
                {% assign highest_variant = variant %}
              {% endif %}
            {% endunless %}
          {% endfor %}
          
          {% comment %} If no Standard variant found, use the highest priced one {% endcomment %}
          {% if standard_variant == nil and highest_variant %}
            {% assign standard_variant = highest_variant %}
            {% assign standard_price = highest_price %}
          {% endif %}
          
          {% comment %} Final fallback to first variant {% endcomment %}
          {% if standard_variant == nil %}
            {% assign standard_variant = featured_product.variants.first %}
            {% assign standard_price = standard_variant.price %}
          {% endif %}
          
          {% comment %} If still no price, use product price {% endcomment %}
          {% if standard_price == 0 %}
            {% assign standard_price = featured_product.price %}
          {% endif %}
        {% endif %}

        <form action="/cart/add" method="post" id="productForm">
          {% if featured_product %}
            <input type="hidden" name="id" id="variantId" value="{{ standard_variant.id }}">
            {% assign discount_percent = section.settings.subscription_discount | default: 10 %}
            <script>
              window.productVariants = {
                default: {{ standard_variant.id }},
                defaultPrice: {{ standard_price }},
                subscriptionDiscount: {{ discount_percent }},
                {% if subscription_variant %}
                subscription: {{ subscription_variant.id }},
                subscriptionPrice: {{ subscription_variant.price }},
                {% endif %}
                {% if free_trial_variant %}
                freeTrial: {{ free_trial_variant.id }},
                freeTrialPrice: {{ free_trial_variant.price }},
                {% endif %}
              };
            </script>
          {% endif %}
          
          <!-- Purchase Tier Selection -->
          <div class="purchase-options">
            <!-- One-Time Purchase -->
            <div class="purchase-option active" data-purchase-type="onetime">
              <div class="purchase-option__header">
                <span class="purchase-option__title">{{ section.settings.option1_title }}</span>
                <span class="purchase-option__price">{{ standard_price | money }}</span>
              </div>
            </div>

            <!-- Subscribe & Save -->
            <div class="purchase-option" data-purchase-type="subscribe">
              <div class="purchase-option__header">
                <div class="purchase-option__title-wrap">
                  <span class="purchase-option__title">{{ section.settings.option2_title }}</span>
                  <span class="purchase-option__badge">Save {{ section.settings.subscription_discount }}%</span>
                </div>
                {% assign discount_percent = section.settings.subscription_discount | default: 10 %}
                {% assign multiplier = 100 | minus: discount_percent %}
                {% assign discounted = standard_price | times: multiplier | divided_by: 100 %}
                <span class="purchase-option__price">{{ discounted | money }}</span>
              </div>
              <p class="purchase-option__subtitle">{{ section.settings.option2_subtitle }}</p>
            </div>

            <!-- Free Journal Trial -->
            {% if section.settings.enable_free_trial %}
            <div class="purchase-option purchase-option--trial" data-purchase-type="first-free">
              <div class="trial-ribbon">
                <span>{{ section.settings.option3_badge }}</span>
              </div>
              <div class="trial-content">
                <div class="trial-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
                  </svg>
                </div>
                <div class="trial-info">
                  <span class="trial-label">{{ section.settings.option3_title }}</span>
                  <span class="trial-price">$0.00</span>
                </div>
                <p class="trial-note">{{ section.settings.option3_subtitle }}</p>
              </div>
              
              <!-- Email & Check Eligibility (shown when selected) -->
              <div class="first-free-form" id="firstFreeForm">
                <input type="email" name="customer_email" id="customerEmail" class="first-free-form__input" placeholder="{{ section.settings.email_placeholder }}">
                
                <!-- Weekly Bookmark Newsletter Opt-in -->
                <label class="first-free-form__newsletter">
                  <input type="checkbox" name="newsletter_optin" id="newsletterOptin" value="1">
                  <span class="first-free-form__newsletter-label">
                    <span class="first-free-form__newsletter-title">Weekly Bookmark</span>
                    <span class="first-free-form__newsletter-desc">Get weekly inspiration, journaling tips & exclusive offers delivered to your inbox.</span>
                  </span>
                </label>
                
                <button type="button" id="checkEligibilityBtn" class="first-free-form__eligibility-btn">
                  <span class="btn-text">Check Eligibility</span>
                </button>
                <div class="first-free-form__status" id="emailStatus"></div>
              </div>
            </div>
            {% endif %}
          </div>

          <!-- Cart Controls -->
          <div class="product-actions">
            <div class="quantity-selector" id="quantitySelector">
              <button type="button" class="quantity-selector__btn quantity-selector__btn--minus">−</button>
              <input type="number" name="quantity" id="quantity" value="1" min="1" class="quantity-selector__input">
              <button type="button" class="quantity-selector__btn quantity-selector__btn--plus">+</button>
            </div>
            <button type="submit" class="btn-add-to-cart" id="addToCartBtn">
              <span class="btn-text">{{ section.settings.add_to_cart_text }}</span>
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

