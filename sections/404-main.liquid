{%- comment -%}
  404 Page Section - Lori J. Smith Theme
{%- endcomment -%}

<section class="error-404-section">
  <div class="error-404-container">
    <h1 class="error-404-title">{{ section.settings.title | default: 'Page Not Found' }}</h1>
    <p class="error-404-text">{{ section.settings.message | default: "Sorry, we couldn't find the page you're looking for." }}</p>
    <a href="{{ routes.root_url }}" class="error-404-btn">
      {{ section.settings.button_text | default: 'Return Home' }}
    </a>
  </div>
</section>

<style>
  .error-404-section {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 80px 20px;
    background-color: #FAF7F2;
    text-align: center;
  }
  
  .error-404-container {
    max-width: 600px;
  }
  
  .error-404-title {
    font-family: var(--font-heading, 'Playfair Display', serif);
    font-size: 56px;
    font-weight: 300;
    color: #000;
    margin-bottom: 24px;
  }
  
  .error-404-text {
    font-family: var(--font-body, 'Josefin Sans', sans-serif);
    font-size: 18px;
    color: #6B7280;
    margin-bottom: 40px;
    line-height: 1.7;
  }
  
  .error-404-btn {
    display: inline-block;
    background-color: #000;
    color: #fff;
    padding: 20px 48px;
    font-family: var(--font-nav, 'Inter', sans-serif);
    font-size: 11px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    font-weight: 700;
    text-decoration: none;
    transition: background-color 0.3s ease;
  }
  
  .error-404-btn:hover {
    background-color: #8B7355;
  }
</style>

{% schema %}
{
  "name": "404 Page",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Page Not Found"
    },
    {
      "type": "textarea",
      "id": "message",
      "label": "Message",
      "default": "Sorry, we couldn't find the page you're looking for."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Return Home"
    }
  ]
}
{% endschema %}
