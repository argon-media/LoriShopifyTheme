<script>
(function() {
  'use strict';

  function ready(fn) {
    if (document.readyState !== 'loading') fn();
    else document.addEventListener('DOMContentLoaded', fn);
  }

  ready(function() {

    /* =============================================
       1. STICKY SIDEBAR CLOSE
       ============================================= */
    var stickyBtns = document.getElementById('sticky-buttons');
    if (stickyBtns) {
      var closeSpan = document.createElement('span');
      closeSpan.className = 'close';
      stickyBtns.prepend(closeSpan);
      closeSpan.addEventListener('click', function() {
        stickyBtns.style.display = 'none';
      });
    }

    /* =============================================
       2. FADE-IN ANIMATIONS (IntersectionObserver)
       ============================================= */
    var animEls = document.querySelectorAll('[data-animation="fadeIn"]');
    if (animEls.length) {
      animEls.forEach(function(el) {
        el.style.opacity = '0';
        el.style.transform = 'translateY(30px)';
        el.style.transition = 'opacity 0.6s ease-out, transform 0.6s ease-out';
      });

      var animObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.style.opacity = '1';
            entry.target.style.transform = 'translateY(0)';
            animObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

      animEls.forEach(function(el) { animObserver.observe(el); });
    }

    /* =============================================
       3. SCROLL-TO-SECTION LINKS
       ============================================= */
    document.querySelectorAll('[data-to-section]').forEach(function(link) {
      link.addEventListener('click', function(e) {
        e.preventDefault();
        var targetId = this.getAttribute('data-to-section');
        var offsetData = this.getAttribute('data-offset');
        var offset = 50;
        try {
          var parsed = JSON.parse(offsetData.replace(/&quot;/g, '"'));
          offset = parsed.all || 50;
        } catch(ex) {}

        var target = document.querySelector('[data-section-id="' + targetId + '"]');
        if (target) {
          var top = target.getBoundingClientRect().top + window.pageYOffset - offset;
          window.scrollTo({ top: top, behavior: 'smooth' });
        }
      });
    });

    /* =============================================
       4. REVEAL HIDDEN SLIDER CONTAINERS
       Elements with visibility:hidden need to be shown
       once we initialise the sliders
       ============================================= */
    document.querySelectorAll('[data-slider]').forEach(function(el) {
      el.style.visibility = 'visible';
      el.style.opacity = '1';
      el.style.height = 'auto';
    });

    /* =============================================
       5. GLIDER / SLIDER ENGINE
       Reads data-slider config and creates a
       touch-friendly, responsive carousel.
       ============================================= */
    function parseSliderConfig(raw) {
      try {
        return JSON.parse(raw.replace(/'/g, '"'));
      } catch(e) { return null; }
    }

    function getBreakpoint() {
      var w = window.innerWidth;
      if (w >= 1200) return 'all';
      if (w >= 1025) return 'laptop';
      if (w >= 768) return 'tablet';
      return 'mobile';
    }

    function getSlidesPerView(cfg) {
      var bp = getBreakpoint();
      var show = cfg.slidesToShow || {};
      return show[bp] || show.all || 1;
    }

    function getScrollCount(cfg) {
      var bp = getBreakpoint();
      var scroll = cfg.slidesToScroll || {};
      return scroll[bp] || scroll.all || 1;
    }

    function initSlider(container) {
      var configStr = container.getAttribute('data-slider');
      var cfg = parseSliderConfig(configStr);
      if (!cfg) return;

      var track = container.querySelector('.glider-track') || container.querySelector('.glider');
      if (!track) return;

      var slides = track.querySelectorAll('.glide-wrapper');
      if (!slides.length) return;

      var current = 0;
      var autoPlayTimer = null;

      function getPerView() { return getSlidesPerView(cfg); }
      function getScroll() { return getScrollCount(cfg); }
      function maxIndex() { return Math.max(0, slides.length - getPerView()); }

      function updateLayout() {
        var perView = getPerView();
        var gap = 10;
        slides.forEach(function(s) {
          s.style.flex = '0 0 calc(' + (100 / perView) + '% - ' + gap + 'px)';
          s.style.maxWidth = 'calc(' + (100 / perView) + '% - ' + gap + 'px)';
          s.style.marginRight = gap + 'px';
          s.style.boxSizing = 'border-box';
        });
        track.style.display = 'flex';
        track.style.transition = 'transform 0.5s ease';
        goTo(current, false);
      }

      function goTo(idx, animate) {
        if (idx < 0) idx = cfg.loop ? slides.length - getPerView() : 0;
        if (idx > maxIndex()) idx = cfg.loop ? 0 : maxIndex();
        current = idx;

        var perView = getPerView();
        var gap = 10;
        var slideW = (track.parentElement.offsetWidth - gap * (perView - 1)) / perView + gap;
        var offset = -(current * slideW);

        if (animate === false) track.style.transition = 'none';
        else track.style.transition = 'transform 0.5s ease';

        track.style.transform = 'translateX(' + offset + 'px)';

        if (animate === false) {
          track.offsetHeight;
          track.style.transition = 'transform 0.5s ease';
        }

        updateNavState();
      }

      function next() { goTo(current + getScroll(), true); }
      function prev() { goTo(current - getScroll(), true); }

      function updateNavState() {
        var prevBtn = container.querySelector('.glider-prev');
        var nextBtn = container.querySelector('.glider-next');
        if (!cfg.loop) {
          if (prevBtn) prevBtn.classList.toggle('disabled', current <= 0);
          if (nextBtn) nextBtn.classList.toggle('disabled', current >= maxIndex());
        }
        if (prevBtn) prevBtn.style.opacity = '1';
        if (nextBtn) nextBtn.style.opacity = '1';
      }

      var prevBtn = container.querySelector('.glider-prev');
      var nextBtn = container.querySelector('.glider-next');
      if (prevBtn) prevBtn.addEventListener('click', prev);
      if (nextBtn) nextBtn.addEventListener('click', next);

      // Touch / drag support
      var startX = 0, startY = 0, isDragging = false, moved = false;
      var glider = track.parentElement;

      glider.addEventListener('touchstart', function(e) {
        startX = e.touches[0].clientX;
        startY = e.touches[0].clientY;
        isDragging = true; moved = false;
      }, { passive: true });

      glider.addEventListener('touchmove', function(e) {
        if (!isDragging) return;
        var dx = e.touches[0].clientX - startX;
        var dy = e.touches[0].clientY - startY;
        if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 10) moved = true;
      }, { passive: true });

      glider.addEventListener('touchend', function(e) {
        if (!isDragging) return;
        isDragging = false;
        if (!moved) return;
        var endX = e.changedTouches[0].clientX;
        var diff = endX - startX;
        if (diff < -40) next();
        else if (diff > 40) prev();
      });

      // Auto-play
      function startAutoPlay() {
        if (!cfg.autoPlay) return;
        var delay = cfg.autoPlayDelay || 5000;
        autoPlayTimer = setInterval(next, delay);
      }

      function stopAutoPlay() {
        if (autoPlayTimer) clearInterval(autoPlayTimer);
      }

      if (cfg.pauseOnHover) {
        container.addEventListener('mouseenter', stopAutoPlay);
        container.addEventListener('mouseleave', startAutoPlay);
      }

      updateLayout();
      startAutoPlay();

      var resizeTimer;
      window.addEventListener('resize', function() {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(updateLayout, 200);
      });
    }

    document.querySelectorAll('[data-slider]').forEach(initSlider);

    /* =============================================
       6. LAZY BACKGROUND IMAGES
       Remove pf-bg-lazy class when in viewport so
       the CSS background-image rules take effect.
       ============================================= */
    var lazyBgObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('pf-bg-loaded');
          lazyBgObserver.unobserve(entry.target);
        }
      });
    }, { rootMargin: '200px' });

    document.querySelectorAll('.pf-bg-lazy').forEach(function(el) {
      lazyBgObserver.observe(el);
    });

    /* =============================================
       7. COUNTDOWN TIMER
       Reads data-translation config and counts
       down to the endTime.
       ============================================= */
    document.querySelectorAll('[data-pf-type="CountDown"]').forEach(function(cd) {
      var raw = cd.getAttribute('data-translation');
      if (!raw) return;
      try {
        var cfg = JSON.parse(raw.replace(/&quot;/g, '"').replace(/&amp;/g, '&'));
        var endTime = new Date(cfg.endTime).getTime();
        var hideIfInactive = cfg.hideIfInactive;
        var timeData = cfg.timeData || {};

        function updateCountdown() {
          var now = Date.now();
          var diff = endTime - now;
          if (diff <= 0) {
            if (hideIfInactive) cd.style.display = 'none';
            return;
          }
          cd.style.visibility = 'visible';
          var d = Math.floor(diff / 86400000);
          var h = Math.floor((diff % 86400000) / 3600000);
          var m = Math.floor((diff % 3600000) / 60000);
          var s = Math.floor((diff % 60000) / 1000);
          var map = { d: d, h: h, m: m, s: s };
          Object.keys(map).forEach(function(key) {
            var el = cd.querySelector('.' + key + ' [data-pf-type="CountdownNumber"]');
            if (el) el.textContent = String(map[key]).padStart(2, '0');
            var label = cd.querySelector('.' + key + ' [data-pf-type="CountdownLabel"]');
            if (label && timeData[key]) label.textContent = timeData[key].text;
          });
        }

        updateCountdown();
        setInterval(updateCountdown, 1000);
      } catch(e) {}
    });

    /* =============================================
       8. ACCORDION (details/summary with animation)
       ============================================= */
    document.querySelectorAll('.kIZjuh').forEach(function(acc) {
      var details = acc.querySelector('details');
      if (!details) { details = acc.closest('details'); }
      if (!details) return;
      if (details.open) acc.classList.add('open');
      details.addEventListener('toggle', function() {
        if (details.open) acc.classList.add('open');
        else acc.classList.remove('open');
      });
    });

  });
})();
</script>

